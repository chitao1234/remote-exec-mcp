# MSVC/NMAKE entry point for remote-exec-daemon-cpp.
#
# Host-native MSVC build from a Visual Studio developer prompt:
#   nmake /f NMakefile check-msvc-native
#
# Windows XP-compatible MSVC build from an x86 Visual Studio developer prompt
# with an XP-capable toolset, for example:
#   vcvarsall.bat x86 -vcvars_ver=14.16
#   nmake /f NMakefile check-msvc-xp
#
# POSIX daemon and host-native POSIX tests remain on the GNU/BSD make paths.

!IFNDEF DAEMON_CPP_DIR
!IF EXIST(src\main.cpp)
DAEMON_CPP_DIR=.
!ELSEIF EXIST(crates\remote-exec-daemon-cpp\src\main.cpp)
DAEMON_CPP_DIR=crates\remote-exec-daemon-cpp
!ELSE
!ERROR Unable to locate remote-exec-daemon-cpp sources. Run nmake from the daemon directory, run from the repository root, or set DAEMON_CPP_DIR.
!ENDIF
!ENDIF

!IFNDEF BUILD_DIR
BUILD_DIR=$(DAEMON_CPP_DIR)\build
!ENDIF

CXX=cl

MSVC_NATIVE_OBJ_DIR=$(BUILD_DIR)\obj\msvc-native
MSVC_NATIVE_TEST_OBJ_DIR=$(BUILD_DIR)\obj\msvc-native-test
MSVC_NATIVE_TARGET=$(BUILD_DIR)\remote-exec-daemon-cpp-msvc.exe
MSVC_NATIVE_SESSION_STORE_TEST=$(BUILD_DIR)\test_session_store-msvc.exe
MSVC_NATIVE_TRANSFER_TEST=$(BUILD_DIR)\test_transfer-msvc.exe

MSVC_XP_OBJ_DIR=$(BUILD_DIR)\obj\msvc-xp
MSVC_XP_TEST_OBJ_DIR=$(BUILD_DIR)\obj\msvc-xp-test
MSVC_XP_TARGET=$(BUILD_DIR)\remote-exec-daemon-cpp-xp-msvc.exe
MSVC_XP_SESSION_STORE_TEST=$(BUILD_DIR)\test_session_store-xp-msvc.exe
MSVC_XP_TRANSFER_TEST=$(BUILD_DIR)\test_transfer-xp-msvc.exe

!IFNDEF MSVC_XP_WINSDK_DIR
MSVC_XP_WINSDK_DIR=C:\Program Files (x86)\Microsoft SDKs\Windows\v7.1A
!ENDIF

MSVC_COMMON_CPPFLAGS=/I"$(DAEMON_CPP_DIR)\include" /I"$(DAEMON_CPP_DIR)\third_party" \
    /DWIN32 /D_WINDOWS \
    /DNOMINMAX /D_CRT_SECURE_NO_WARNINGS /D_CRT_NONSTDC_NO_DEPRECATE
MSVC_NATIVE_CPPFLAGS=$(MSVC_COMMON_CPPFLAGS)
MSVC_XP_CPPFLAGS=$(MSVC_COMMON_CPPFLAGS) /I"$(MSVC_XP_WINSDK_DIR)\Include" \
    /DWINVER=0x0501 /D_WIN32_WINNT=0x0501 /D_USING_V110_SDK71_

MSVC_CXXFLAGS=/nologo /EHsc /MT /W3 /Od /std:c++14
MSVC_LDLIBS=ws2_32.lib
MSVC_NATIVE_LDFLAGS=/link /NOLOGO /SUBSYSTEM:CONSOLE
MSVC_XP_LDFLAGS=/link /NOLOGO /LIBPATH:"$(MSVC_XP_WINSDK_DIR)\Lib" /SUBSYSTEM:CONSOLE,5.01 /MACHINE:X86

!IFNDEF TEST_LOG_LEVEL
!IFDEF REMOTE_EXEC_LOG
TEST_LOG_LEVEL=$(REMOTE_EXEC_LOG)
!ELSEIFDEF REMOTE_EXEC_TEST_LOG
TEST_LOG_LEVEL=$(REMOTE_EXEC_TEST_LOG)
!ELSE
TEST_LOG_LEVEL=off
!ENDIF
!ENDIF

SOURCE_PREFIX=$(DAEMON_CPP_DIR)/
!include "$(DAEMON_CPP_DIR)\mk\sources.mk"

MSVC_WIN32_DAEMON_SRCS= \
    $(BASE_SRCS) \
    $(SOURCE_PREFIX)src/main.cpp \
    $(SOURCE_PREFIX)src/process_session_win32.cpp \
    $(SOURCE_PREFIX)src/console_output.cpp \
    $(SOURCE_PREFIX)src/win32_error.cpp

MSVC_WIN32_SESSION_STORE_TEST_SRCS= \
    $(SOURCE_PREFIX)tests/test_session_store.cpp \
    $(SOURCE_PREFIX)src/session_store.cpp \
    $(SOURCE_PREFIX)src/session_pump.cpp \
    $(SOURCE_PREFIX)src/process_session_win32.cpp \
    $(SOURCE_PREFIX)src/platform.cpp \
    $(SOURCE_PREFIX)src/shell_policy.cpp \
    $(SOURCE_PREFIX)src/console_output.cpp \
    $(SOURCE_PREFIX)src/basic_mutex.cpp \
    $(SOURCE_PREFIX)src/logging.cpp \
    $(SOURCE_PREFIX)src/win32_error.cpp \
    $(SOURCE_PREFIX)src/config.cpp \
    $(SOURCE_PREFIX)src/text_utils.cpp

MSVC_WIN32_TRANSFER_TEST_SRCS= \
    $(SOURCE_PREFIX)tests/test_transfer.cpp \
    $(PATH_UTILS_SRCS) \
    $(TRANSFER_SRCS) \
    $(RPC_FAILURE_SRCS)

all: all-msvc-native

all-msvc-native: $(MSVC_NATIVE_TARGET)

all-msvc-xp: $(MSVC_XP_TARGET)

test-msvc-native: test-msvc-native-session-store test-msvc-native-transfer

test-msvc-native-session-store: $(MSVC_NATIVE_SESSION_STORE_TEST)
	@set "REMOTE_EXEC_LOG=$(TEST_LOG_LEVEL)" && "$(MSVC_NATIVE_SESSION_STORE_TEST)"

test-msvc-native-transfer: $(MSVC_NATIVE_TRANSFER_TEST)
	@set "REMOTE_EXEC_LOG=$(TEST_LOG_LEVEL)" && "$(MSVC_NATIVE_TRANSFER_TEST)"

test-msvc-xp: test-msvc-xp-session-store test-msvc-xp-transfer

test-msvc-xp-session-store: $(MSVC_XP_SESSION_STORE_TEST)
	@set "REMOTE_EXEC_LOG=$(TEST_LOG_LEVEL)" && "$(MSVC_XP_SESSION_STORE_TEST)"

test-msvc-xp-transfer: $(MSVC_XP_TRANSFER_TEST)
	@set "REMOTE_EXEC_LOG=$(TEST_LOG_LEVEL)" && "$(MSVC_XP_TRANSFER_TEST)"

check-msvc-native: all-msvc-native test-msvc-native

check-msvc-xp: all-msvc-xp test-msvc-xp

$(MSVC_NATIVE_TARGET): $(MSVC_WIN32_DAEMON_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_NATIVE_OBJ_DIR)" mkdir "$(MSVC_NATIVE_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_NATIVE_CPPFLAGS) /Fo"$(MSVC_NATIVE_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_DAEMON_SRCS) $(MSVC_LDLIBS) $(MSVC_NATIVE_LDFLAGS)

$(MSVC_NATIVE_SESSION_STORE_TEST): $(MSVC_WIN32_SESSION_STORE_TEST_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_NATIVE_TEST_OBJ_DIR)" mkdir "$(MSVC_NATIVE_TEST_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_NATIVE_CPPFLAGS) /Fo"$(MSVC_NATIVE_TEST_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_SESSION_STORE_TEST_SRCS) $(MSVC_LDLIBS) $(MSVC_NATIVE_LDFLAGS)

$(MSVC_NATIVE_TRANSFER_TEST): $(MSVC_WIN32_TRANSFER_TEST_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_NATIVE_TEST_OBJ_DIR)" mkdir "$(MSVC_NATIVE_TEST_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_NATIVE_CPPFLAGS) /Fo"$(MSVC_NATIVE_TEST_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_TRANSFER_TEST_SRCS) $(MSVC_LDLIBS) $(MSVC_NATIVE_LDFLAGS)

$(MSVC_XP_TARGET): $(MSVC_WIN32_DAEMON_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_XP_OBJ_DIR)" mkdir "$(MSVC_XP_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_XP_CPPFLAGS) /Fo"$(MSVC_XP_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_DAEMON_SRCS) $(MSVC_LDLIBS) $(MSVC_XP_LDFLAGS)

$(MSVC_XP_SESSION_STORE_TEST): $(MSVC_WIN32_SESSION_STORE_TEST_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_XP_TEST_OBJ_DIR)" mkdir "$(MSVC_XP_TEST_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_XP_CPPFLAGS) /Fo"$(MSVC_XP_TEST_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_SESSION_STORE_TEST_SRCS) $(MSVC_LDLIBS) $(MSVC_XP_LDFLAGS)

$(MSVC_XP_TRANSFER_TEST): $(MSVC_WIN32_TRANSFER_TEST_SRCS)
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\obj" mkdir "$(BUILD_DIR)\obj"
	@if not exist "$(MSVC_XP_TEST_OBJ_DIR)" mkdir "$(MSVC_XP_TEST_OBJ_DIR)"
	$(CXX) $(MSVC_CXXFLAGS) $(MSVC_XP_CPPFLAGS) /Fo"$(MSVC_XP_TEST_OBJ_DIR)\\" /Fe"$@" $(MSVC_WIN32_TRANSFER_TEST_SRCS) $(MSVC_LDLIBS) $(MSVC_XP_LDFLAGS)

clean:
	@if exist "$(MSVC_NATIVE_TARGET)" del /Q "$(MSVC_NATIVE_TARGET)"
	@if exist "$(MSVC_NATIVE_SESSION_STORE_TEST)" del /Q "$(MSVC_NATIVE_SESSION_STORE_TEST)"
	@if exist "$(MSVC_NATIVE_TRANSFER_TEST)" del /Q "$(MSVC_NATIVE_TRANSFER_TEST)"
	@if exist "$(MSVC_XP_TARGET)" del /Q "$(MSVC_XP_TARGET)"
	@if exist "$(MSVC_XP_SESSION_STORE_TEST)" del /Q "$(MSVC_XP_SESSION_STORE_TEST)"
	@if exist "$(MSVC_XP_TRANSFER_TEST)" del /Q "$(MSVC_XP_TRANSFER_TEST)"
	@if exist "$(MSVC_NATIVE_OBJ_DIR)" rmdir /S /Q "$(MSVC_NATIVE_OBJ_DIR)"
	@if exist "$(MSVC_NATIVE_TEST_OBJ_DIR)" rmdir /S /Q "$(MSVC_NATIVE_TEST_OBJ_DIR)"
	@if exist "$(MSVC_XP_OBJ_DIR)" rmdir /S /Q "$(MSVC_XP_OBJ_DIR)"
	@if exist "$(MSVC_XP_TEST_OBJ_DIR)" rmdir /S /Q "$(MSVC_XP_TEST_OBJ_DIR)"

.PHONY: all all-msvc-native all-msvc-xp test-msvc-native test-msvc-native-session-store test-msvc-native-transfer test-msvc-xp test-msvc-xp-session-store test-msvc-xp-transfer check-msvc-native check-msvc-xp clean
